{
    "manifest_version": 3,
    "name": "Aegis Explorer",
    "version": "3.0",
    "description": "Aegis Explorer protects children online by detecting and blocking potentially harmful images and text using customizable filters.",
    "options_page": "settings.html",
    "permissions": ["storage"],
    "host_permissions": [
        "https://aegisexplorer.org/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["lib/nsfwjs.min.js", "contentScript.js"],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "models/nsfwjs/model.json",
                "models/nsfwjs/group1-shard1of1.bin"
            ],
            "matches": ["<all_urls>"]
        }
    ],
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}
